107. (blank)

108. `  for(int i = 0; i < MAX_STEPS; i++){`
     - What: Main raymarch loop.
     - Why: Advances ray until hit/miss.

109. `    vec3 p = ro + rd * dTravel;`
     - What: Current world sample position.
     - Why: March point along ray.

110. `    d = mapScene(p, trap);`
     - What: Gets distance estimate.
     - Why: Distance guides next step size.

111. (blank)

112. `    if(d < HIT_EPS || dTravel > MAX_DIST){`
     - What: Hit or miss condition.
     - Why: Terminates loop safely.

113. `      steps = i;`
     - What: Records iteration count.
     - Why: Used later for coloring.

114. `      break;`
     - What: Exits loop.
     - Why: No further marching needed.

115. `    }`
     - What: Ends condition block.

116. (blank)

117. `    dTravel += d * 0.92;`
     - What: Advances ray by scaled distance.
     - Why: Slightly conservative step avoids overstepping thin features.

118. `    steps = i;`
     - What: Updates steps while marching.
     - Why: Retains latest progress if loop exits by max steps.

119. `  }`
     - What: Ends raymarch loop.

120. (blank)

121. `  vec3 col;`
     - What: Declares final color variable.
     - Why: Assigned in hit/miss branches.

122. (blank)

123. `  if(dTravel < MAX_DIST){`
     - What: Hit branch.
     - Why: If within max range, shade fractal surface.

124. `    vec3 p = ro + rd * dTravel;`
     - What: Reconstructs hit position.
     - Why: Needed for lighting calculations.

125. `    vec3 n = calcNormal(p);`
     - What: Computes normal.
     - Why: Diffuse/specular lighting depends on surface orientation.

126. (blank)

127. `    vec3 lightPos = vec3(6.0, 7.0, 5.0);`
     - What: Light world position.
     - Why: Defines single key light.

128. `    vec3 l = normalize(lightPos - p);`
     - What: Light direction.
     - Why: Used in Lambert and Blinn-Phong terms.

129. `    vec3 v = normalize(ro - p);`
     - What: View direction.
     - Why: Needed for specular and Fresnel.

130. `    vec3 h = normalize(l + v);`
     - What: Half-vector.
     - Why: Blinn-Phong specular formulation.

131. (blank)

132. `    float diff = max(dot(n, l), 0.0);`
     - What: Diffuse term.
     - Why: Basic light intensity from incident angle.

133. `    float spec = pow(max(dot(n, h), 0.0), 60.0);`
     - What: Specular highlight.
     - Why: Adds glossy bright accents.

134. `    float fres = pow(1.0 - max(dot(n, v), 0.0), 3.0);`
     - What: Fresnel-like rim factor.
     - Why: Emphasizes silhouette edges and depth.

135. (blank)

136. `    float s = float(steps) / float(MAX_STEPS);`
     - What: Normalized step count.
     - Why: Encodes geometric complexity for color ramp.

137. `    vec3 base = mix(vec3(0.05, 0.14, 0.35), vec3(0.95, 0.55, 0.22), smoothstep(0.05, 0.95, s));`
     - What: Builds base gradient color.
     - Why: Maps march complexity to warm/cool palette.

138. `    base += vec3(0.2, 0.1, 0.25) * exp(-3.0 * trap);`
     - What: Adds orbit-trap tint.
     - Why: Reveals internal fractal strata.

139. (blank)

140. `    col = base * (0.13 + 1.25 * diff) + 0.75 * spec + 0.35 * fres;`
     - What: Final lit color.
     - Why: Combines ambient-like baseline, diffuse, specular, rim.

141. `  } else {`
     - What: Miss branch start.
     - Why: Shade background when ray does not hit fractal.

142. `    float g = 0.5 + 0.5 * rd.y;`
     - What: Vertical gradient factor.
     - Why: Sky-like directional background.

143. `    col = mix(vec3(0.01, 0.01, 0.02), vec3(0.06, 0.09, 0.15), g);`
